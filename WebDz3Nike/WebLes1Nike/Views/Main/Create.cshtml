@model WebLes1Nike.Models.Category.CategoryCreateViewModel

<h1 class="text-center mb-5 fw-bold">Створити категорію</h1>
<div class="row">
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="col-md-6 offset-md-3">
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Назва категорії</label>
            <input asp-for="Name" class="form-control" maxlength="250">
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Slug" class="form-label">Slug (URL)</label>
            <input asp-for="Slug" class="form-control" maxlength="250">
            <span asp-validation-for="Slug" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Image" class="form-label">Зображення (URL або шлях)</label>
            <input asp-for="Image" class="form-control" maxlength="100">
            <div id="imageHelp" class="form-text">Необов'язкове поле</div>
        </div>
        <button type="submit" class="btn btn-primary">Зберегти</button>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/slugify@1.6.9/slugify.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", ()=>{
            const Name = document.getElementById("Name");
            const Slug = document.getElementById("Slug");
            Name.addEventListener("input", ()=>{
                Slug.value = slugify(Name.value, { 
                    lower: true, 
                    strict: true,
                    trim: true
                });
            });
        });
    </script>
}