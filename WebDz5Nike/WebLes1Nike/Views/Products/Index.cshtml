@model List<WebLes1Nike.Data.Entities.ProductEntity>

<h1 class="text-center mb-5 fw-bold">Список товарів Nike</h1>

<a asp-action="ProdCreate" class="btn btn-secondary mb-3">Додати новий товар</a>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

    @foreach (var prod in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm category-card border-0">
                <img src="/images/@($"{prod.ProductImages.FirstOrDefault()?.Name}_432.webp")" class="card-img-top category-img" alt="@prod.Name">
                <div class="card-body text-center">
                    <h3 class="card-title fw-bold">@prod.Name</h3>
                    <span class="badge bg-dark">@prod.Category?.Name</span>
                    <h3 class="price mt-3">$ @prod.Price</h3>

                    <div class="card-footer bg-white border-0">
                        <a href="#"
                           class="btn btn-dark w-100">
                            Переглянути
                        </a>
                    </div>
                </div>
            </div>
        </div>

    }
</div>

                