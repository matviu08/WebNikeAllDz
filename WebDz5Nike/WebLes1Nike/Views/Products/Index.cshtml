@model List<WebLes1Nike.Data.Entities.ProductEntity>

<h1 class="text-center mb-5 fw-bold">Список товарів Nike</h1>

<a asp-action="ProdCreate" class="btn btn-secondary mb-3">Додати новий товар</a>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

    @foreach (var cat in Model)
    {
        var modalId = $"confirmDelete{cat.Id}";
        <div class="col">
            <div class="card h-100 shadow-sm category-card border-0">
                <img src="/images/@($"{cat.Image}_432.webp")" class="card-img-top category-img" alt="@cat.Name">
                <div class="card-body d-flex flex-column text-center">
                    <h3 class="card-title mb-2">@cat.Name</h3>
                    <h5 class="form-text mb-4">@cat.Slug</h5>
                    <h5 class="form-text mb-4">@cat.Prise</h5>

                    <a href="#" class="btn btn-dark w-100 mb-2">
                        Переглянути
                    </a>
                </div>
            </div>
        </div>

    }
</div>