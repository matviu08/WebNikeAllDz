@model List<WebLes1Nike.Data.Entities.CategoryEntitiy>


<h1 class="text-center mb-5 fw-bold">Категорії товарів Nike</h1>

<a asp-action="Create" class="btn btn-secondary mb-3">Додати нову категорію</a>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

    @foreach (var cat in Model)
    {
        var modalId = $"confirmDelete{cat.Id}";
        <div class="col">
            <div class="card h-100 shadow-sm category-card border-0">
                <img src="/images/@($"{cat.Image}_432.webp")" class="card-img-top category-img" alt="@cat.Name">
                <div class="card-body d-flex flex-column text-center">
                    <h3 class="card-title mb-2">@cat.Name</h3>
                    <h5 class="form-text mb-4">@cat.Slug</h5>

                    <a href="#" class="btn btn-dark w-100 mb-2">
                        Переглянути
                    </a>

                    <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-outline-primary w-100 mb-2">
                        Редагувати
                    </a>

                    <button type="button"
                            data-bs-toggle="modal" data-bs-target="#@modalId"
                            class="btn btn-danger w-100">
                        Видалити
                    </button>
                </div>
            </div>
        </div>

        <div class="modal fade" id="@modalId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="Label_@modalId">Підтвердіть інформацію</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>
                            Ви дійсно бажаєте видалити категорію
                            <strong>"@cat.Name"</strong>?
                        </p>

                        <p class="text-danger mb-0">
                            Після видалення відновити її буде неможливо.
                        </p>

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>

                        <form asp-action="Delete" asp-route-id="@cat.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">Видалити назавжди</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>