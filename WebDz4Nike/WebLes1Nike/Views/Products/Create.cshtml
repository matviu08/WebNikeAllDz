@model WebLes1Nike.Models.Product.CrateProductViewModel

<h1 class="text-center mb-5 fw-bold">Створити товар</h1>
<div class="row">
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="col-md-8 offset-md-2">
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Назва товар</label>
            <input asp-for="Name" class="form-control">
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Slug" class="form-label">Slug (URL)</label>
            <input asp-for="Slug" class="form-control">
            <span asp-validation-for="Slug" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <span asp-validation-for="CategoryName" class="text-danger"></span>
            @{
                var categories = ViewBag.Categories;
            }
            <select class="form-select" asp-for="CategoryName">
                @foreach (var catName in categories)
                {
                    <option value="@catName">@catName</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="Price" class="form-label">Ціна</label>
            <input asp-for="Price" class="form-control" type="number" step="0.01">
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Опис</label>
            <textarea asp-for="Description" id="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Фото товару</label>

            <div id="imageDropzone" class="image-dropzone">
                Перетягніть сюди фото або натисніть, щоб вибрати
            </div>
            <input type="file" id="imageInput" accept="image/*" multiple hidden>

            <div id="imagePreviewList" class="image-preview-list"></div>

            <div id="imagesHiddenInputs"></div>
        </div>

        <button type="submit" class="btn btn-primary">Зберегти</button>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/slugify@1.6.9/slugify.min.js"></script>
    <script src="~/lib/tinymce/tinymce.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const Name = document.getElementById("Name");
            const Slug = document.getElementById("Slug");
            Name.addEventListener("input", () => {
                Slug.value = slugify(Name.value, {
                    lower: true,
                    strict: true,
                    trim: true
                });
            });
        });
    </script>

    <script>
        tinymce.init({
            selector: "#Description",
            height: 350,
            menubar: false,
            plugins: "lists link image preview fullscreen",
            toolbar: "bold italic | alignleft aligncenter alignright alignjustify | " +
                     "bullist numlist | indent outdent | link image | preview fullscreen",
            statusbar: true,
            branding: true,
            license_key: "gpl"
        });
    </script>

    <script>
        (function () {
            const dropzone = document.getElementById("imageDropzone");
            const fileInput = document.getElementById("imageInput");
            const previewList = document.getElementById("imagePreviewList");
            const hiddenInputsContainer = document.getElementById("imagesHiddenInputs");

            let images = [];
            let idCounter = 0;

            dropzone.addEventListener("click", () => fileInput.click());

            dropzone.addEventListener("dragover", (e) => {
                e.preventDefault();
                dropzone.classList.add("dragover");
            });
            dropzone.addEventListener("dragleave", () => {
                dropzone.classList.remove("dragover");
            });
            dropzone.addEventListener("drop", (e) => {
                e.preventDefault();
                dropzone.classList.remove("dragover");
                handleFiles(e.dataTransfer.files);
            });

            fileInput.addEventListener("change", () => {
                handleFiles(fileInput.files);
                fileInput.value = "";
            });

            function handleFiles(fileList) {
                [...fileList].forEach(file => {
                    if (!file.type.startsWith("image/")) return;

                    const reader = new FileReader();
                    reader.onload = (e) => {
                        images.push({ id: idCounter++, dataUrl: e.target.result });
                        renderPreviews();
                    };
                    reader.readAsDataURL(file);
                });
            }

            function removeImage(id) {
                images = images.filter(img => img.id !== id);
                renderPreviews();
            }

            let dragSrcId = null;

            function renderPreviews() {
                previewList.innerHTML = "";

                images.forEach((img, index) => {
                    const item = document.createElement("div");
                    item.className = "image-preview-item";
                    item.draggable = true;
                    item.dataset.id = img.id;

                    item.innerHTML = `
                        <img src="${img.dataUrl}" alt="preview">
                        <span class="image-preview-order">${index + 1}</span>
                        <button type="button" class="image-preview-remove" title="Видалити">&times;</button>
                    `;

                    item.querySelector(".image-preview-remove")
                        .addEventListener("click", () => removeImage(img.id));

                    item.addEventListener("dragstart", () => {
                        dragSrcId = img.id;
                        item.classList.add("dragging");
                    });
                    item.addEventListener("dragend", () => {
                        item.classList.remove("dragging");
                    });
                    item.addEventListener("dragover", (e) => e.preventDefault());
                    item.addEventListener("drop", (e) => {
                        e.preventDefault();
                        if (dragSrcId === null || dragSrcId === img.id) return;

                        const fromIndex = images.findIndex(i => i.id === dragSrcId);
                        const toIndex = images.findIndex(i => i.id === img.id);
                        const [moved] = images.splice(fromIndex, 1);
                        images.splice(toIndex, 0, moved);

                        dragSrcId = null;
                        renderPreviews();
                    });

                    previewList.appendChild(item);
                });

                syncHiddenInputs();
            }

            function syncHiddenInputs() {
                hiddenInputsContainer.innerHTML = "";

                images.forEach((img, index) => {
                    const base64Field = document.createElement("input");
                    base64Field.type = "hidden";
                    base64Field.name = `Images[${index}].Base64Image`;
                    base64Field.value = img.dataUrl;

                    const orderField = document.createElement("input");
                    orderField.type = "hidden";
                    orderField.name = `Images[${index}].Order`;
                    orderField.value = index + 1;

                    hiddenInputsContainer.appendChild(base64Field);
                    hiddenInputsContainer.appendChild(orderField);
                });
            }
        })();
    </script>
}