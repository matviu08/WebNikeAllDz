@model WebLes1Nike.Models.Category.CategoryEditViewModel

<h1 class="text-center mb-5 fw-bold">Редагувати категорію</h1>
<div class="row">
    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="col-md-6 offset-md-3">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CurrentImage" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Назва категорії</label>
            <input asp-for="Name" class="form-control" maxlength="250">
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Slug" class="form-label">Slug (URL)</label>
            <input asp-for="Slug" class="form-control" maxlength="250">
            <span asp-validation-for="Slug" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label d-block">Поточне зображення</label>
            <img src="/images/@($"{Model.CurrentImage}_432.webp")" alt="@Model.Name" style="max-width:200px" class="img-thumbnail" />
        </div>

        <div class="mb-3">
            <label asp-for="Image" class="form-label">Нове зображення (необов'язково)</label>
            <input asp-for="Image" type="file" class="form-control" accept="image/*">
            <div class="form-text">Залиш порожнім якщо не хочеш змінювати зображення</div>
        </div>

        <button type="submit" class="btn btn-primary">Зберегти зміни</button>
        <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/slugify@1.6.9/slugify.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", ()=>{
            const Name = document.getElementById("Name");
            const Slug = document.getElementById("Slug");
            Name.addEventListener("input", ()=>{
                Slug.value = slugify(Name.value, { 
                    lower: true, 
                    strict: true,
                    trim: true
                });
            });
        });
    </script>
}